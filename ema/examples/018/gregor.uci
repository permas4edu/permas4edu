NEW

INPUT
    READ PERMAS FILE = gregor.dat
RETURN

TASK
EXEC
    ACT SIT = STEP_1
    VIBRATION ANALYSIS MODES = 20
SELECT
    ACTIVE NSET = MP
    XYDATA ITEM DISP COOR = Z RESULT = MP DCOMP = 1
EXPORT
    ITEM CLEAR XYDATA
    ITEM MODL
    GO PERMAS BINARY FILE = normal_modes
    ITEM CLEAR
    ITEM XYDATA TYPE = DISP NAME = MP
    GO PERMAS BINARY FILE = mp
TASK END
STOP
