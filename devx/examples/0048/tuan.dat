   $SYSTEM  NAME = S_STEP_1
!
      $GEODAT BEAM      CONT = SECTTYPE SECTDIM
!                                  diameter
       GD_LINE_1             4 :  2.500000E+01
       GD_LINE_2             4 :  1.000000E+01
       GD_LINE_3             4 :  1.000000E+01
       GD_LINE_4             4 :  1.000000E+01
