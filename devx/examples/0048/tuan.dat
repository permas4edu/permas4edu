       GD_DISK_1     7.800000E-09  1.000000E+01  7.500000E+01    2.500000E+01
       GD_DISK_2     7.800000E-09  1.000000E+01  7.500000E+01    2.500000E+01
!
!     Anisotropic bearings !!
!
      $GEODAT SPRING    CONT = STIFF
