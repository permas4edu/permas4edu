   $END STRUCTURE
!------
   $SYSTEM  NAME = S_STEP_1
!
!     Caution PERMAS makes use of
!     C = alpha K + beta M
!
      $COMPDAMP
        ALPHA = 2.5E-04
! 
      $GEODAT BEAM      CONT = SECTTYPE SECTDIM
       GD_LINE1              4
         &        :  1.600000E+01
       GD_LINE2              4
         &        :  2.000000E+01
       GD_LINE3              4
         &        :  2.500000E+01
       GD_LINE4              4
         &        :  2.500000E+01
       GD_LINE5              4
         &        :  2.500000E+01
       GD_LINE6              4
         &        :  4.500000E+01
       GD_LINE7              4
         &        :  4.500000E+01
       GD_LINE8              4
         &        :  2.500000E+01
       GD_LINE9              4
         &        :  2.500000E+01
       GD_LINE10             4
         &        :  2.500000E+01
       GD_LINE11             4
         &        :  2.500000E+01
       GD_LINE12             4
         &        :  4.500000E+01
       GD_LINE13             4
         &        :  4.500000E+01
       GD_LINE14             4
         &        :  2.500000E+01
       GD_LINE15             4
         &        :  2.500000E+01
       GD_LINE16             4
         &        :  2.500000E+01
       GD_LINE17             4
         &        :  2.000000E+01
       GD_LINE18             4
         &        :  1.800000E+01
      $GEODAT MASS      CONT = CYLINDER
       GD_DISK_1     7.850000E-09  4.500000E+01  1.400000E+02  3.000000E+01
       GD_DISK_2     7.850000E-09  4.500000E+01  1.400000E+02  3.000000E+01
      $GEODAT SPRING    CONT = STIFF
       GD_K_1        0.000000E+00  1.000000E+05  1.000000E+05
       GD_K_2        0.000000E+00  1.000000E+05  1.000000E+05
!
      $GEODAT DAMPER CONT = DAMP
       GD_C_1        0.000000E+00  1.000000E+01  1.000000E+01
       GD_C_2        0.000000E+00  1.000000E+01  1.000000E+01
!
      $ELPROP
       DISK_1        GEODAT = GD_DISK_1
       DISK_2        GEODAT = GD_DISK_2
       K_1           GEODAT = GD_K_1
       K_2           GEODAT = GD_K_2
       C_1           GEODAT = GD_C_1
       C_2           GEODAT = GD_C_2
       LINE1         GEODAT = GD_LINE1      MATERIAL = MAT_SHAFT
       LINE10        GEODAT = GD_LINE10     MATERIAL = MAT_SHAFT
       LINE11        GEODAT = GD_LINE11     MATERIAL = MAT_SHAFT
       LINE12        GEODAT = GD_LINE12     MATERIAL = MAT_SHAFT
       LINE13        GEODAT = GD_LINE13     MATERIAL = MAT_SHAFT
       LINE14        GEODAT = GD_LINE14     MATERIAL = MAT_SHAFT
       LINE15        GEODAT = GD_LINE15     MATERIAL = MAT_SHAFT
       LINE16        GEODAT = GD_LINE16     MATERIAL = MAT_SHAFT
       LINE17        GEODAT = GD_LINE17     MATERIAL = MAT_SHAFT
       LINE18        GEODAT = GD_LINE18     MATERIAL = MAT_SHAFT
       LINE2         GEODAT = GD_LINE2      MATERIAL = MAT_SHAFT
       LINE3         GEODAT = GD_LINE3      MATERIAL = MAT_SHAFT
       LINE4         GEODAT = GD_LINE4      MATERIAL = MAT_SHAFT
       LINE5         GEODAT = GD_LINE5      MATERIAL = MAT_SHAFT
       LINE6         GEODAT = GD_LINE6      MATERIAL = MAT_SHAFT
       LINE7         GEODAT = GD_LINE7      MATERIAL = MAT_SHAFT
       LINE8         GEODAT = GD_LINE8      MATERIAL = MAT_SHAFT
       LINE9         GEODAT = GD_LINE9      MATERIAL = MAT_SHAFT
!
   $END SYSTEM
!------
   $CONSTRAINTS  NAME = C_STEP_1
!
      $SUPPRESS  DOFS = 1,2,3  DOFTYPE = DISP
       GROUND
      $SUPPRESS  DOFS = 1,4  DOFTYPE = DISP
       SHAFT
!
   $END CONSTRAINTS
!------
   $LOADING  NAME = L_STEP_1
!
      $INERTIA ROTATION  LPAT = 1
       ROTOR  0.000000E+00  0.000000E+00  0.000000E+00  1.000000E+02  0.000000E+00  0.000000E+00  1.000000E+00
!
   $END LOADING
!------
   $SYSTEM  NAME = S_STEP_2
!
      $INSERT VARIANT
         S_STEP_1

      $ELSTATE LOAD
         SITUATION = STEP_1  LPAT = 1
 
      $ADDMATRIX
         GEOSTIFF
         CONVSTIFF
         GYRO
!
   $END SYSTEM
!------
   $RESULTS NAME = R_STEP_3

     $ROTSPEED PRIMARY = EQUI
        0.0 20.5 0.5

   $END RESULTS
!------
$EXIT COMPONENT
!------------------------------------
$ENTER MATERIAL
!------
   $MATERIAL  NAME = MAT_SHAFT  TYPE = ISO
!
      $ELASTIC  GENERAL  INPUT = DATA
        2.000000E+05  3.000000E-01
!
      $DENSITY  GENERAL  INPUT = DATA
        7.850000E-09
!
   $END MATERIAL
!------
$EXIT MATERIAL
!------------------------------------
$FIN
