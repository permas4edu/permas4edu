SET MODETRACKING = LASTITER

NEW

INPUT
    READ PERMAS FILE = modal_interaction.dat
    READ PERMAS FILE = modal_interaction_sampling.dat
RETURN

TASK LOOPS =  123 !  41
EXEC
    ACT SIT = STEP_1
    VIBRATION ANALYSIS MODES = 2
    ACT SIT = SAMPLING
    SAMPLING
TASK END
EXPORT
    ITEM CLEAR
    ITEM XYDATA TYPE = DHIS
    ITEM XYDATA TYPE = SRHIS
    GO PERMAS BINARY FILE = sampling 
    GO SPREADSHEET FILE = sampling
USER
    CALL TOOL6 P1 = 'pyINTES modal_interaction.py'
RETURN
STOP
