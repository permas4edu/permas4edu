NEW
USER
    CALL TOOL6 P1 = 'pyINTES qian_edu.py'
RETURN

INPUT
    READ PERMAS FILE = qian.dat
    READ NEW PERMAS FILE = qian_add.dat
RETURN

TASK
EXEC
    ACT SIT = STEP_1
    VIBRATION ANALYSIS MODES = 20
PRINT
    PORT RES REPLACE FILE = natural_frequencies.txt
    DATA OBJECT RVALTAB.DISP
    PORT RES RESET
EXPORT
    ITEM MODL
    GO PERMAS BINARY FILE = normal_modes
TASK END
STOP
