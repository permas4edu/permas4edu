NEW

INPUT
    READ PERMAS FILE = 2D_beam.dat
RETURN

TASK
EXEC
    ACT SIT = STEP_1
    STATIC
    GEN EL STRAIN
    GEN EL STRESS
EXPORT
    ITEM MODL
    GO PERMAS BINARY FILE = statics
EXEC
    ACT SIT = STEP_2
    VIBRATION ANALYSIS MODES = 5
EXPORT
    ITEM MODL
    GO PERMAS BINARY FILE = normal_modes
TASK END
STOP
