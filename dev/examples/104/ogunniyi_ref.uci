NEW

INPUT
    READ PERMAS FILE =  ogunniyi_ref.dat
RETURN

TASK
EXEC
    ACT SIT = STEP_1
    VIBRATION ANALYSIS MODES = 6
PRINT
    PORT RES REPLACE FILE = natural_frequencies.txt
    TEXT = 'Free-free plate'
    DATA OBJECT RVALTAB.DISP
    PORT RES RESET
EXPORT
    ITEM MODL
    GO PERMAS BINARY FILE = normal_modes_1
EXEC
    ACT SIT = STEP_2
    VIBRATION ANALYSIS MODES = 6
PRINT
    PORT RES SWITCH FILE = natural_frequencies.txt
    TEXT = 'Cantilever plate'
    DATA OBJECT RVALTAB.DISP
    PORT RES RESET
EXPORT
    ITEM MODL
    GO PERMAS BINARY FILE = normal_modes_2
TASK END
STOP
