$ENTER COMPONENT  NAME = DFLT_COMP  DOFTYPE = DISP MATH
!------
   $SITUATION  NAME = STEP_1
      DFLT_COMP  CONSTRAINTS = C_STEP_1  SYSTEM = S_STEP_1
   $END SITUATION
!
   $STRUCTURE
!
      $PART  NAME = SHAFT_01
       SHAFT_01
      $PART  NAME = SHAFT_02
       SHAFT_02
!
   $END STRUCTURE
!------
   $SYSTEM  NAME = S_STEP_1
!
      $ELPROP
       SHAFT_01      MATERIAL = MAT_01
       SHAFT_02      MATERIAL = MAT_02
!
   $END SYSTEM
!------
   $CONSTRAINTS  NAME = C_STEP_1
!
   $END CONSTRAINTS
!------
$EXIT COMPONENT
!------------------------------------
$ENTER MATERIAL
!------
   $MATERIAL  NAME = MAT_01  TYPE = ISO
!
      $ELASTIC  GENERAL  INPUT = DATA
        2.050000E+05  3.000000E-01
!
      $DENSITY  GENERAL  INPUT = DATA
        7.780000E-09
!
   $END MATERIAL
!------
   $MATERIAL  NAME = MAT_02  TYPE = ISO
!
      $ELASTIC  GENERAL  INPUT = DATA
        2.050000E+05  3.000000E-01
!
      $DENSITY  GENERAL  INPUT = DATA
        7.780000E-09
!
   $END MATERIAL
!------
$EXIT MATERIAL
!------------------------------------
$FIN
