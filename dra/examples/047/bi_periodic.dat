$DEFVAR M TYPE = REAL LIST = 1.0
$DEFVAR GAMMA TYPE = REAL LIST = 0.2
$DEFVAR F TYPE = REAL LIST = 5.0 5.0
$DEFVAR C TYPE = REAL LIST = 0.1
$DEFVAR K TYPE = REAL LIST = 1.0
$DEFVAR FREQ TYPE = REAL LIST = 1.0

$ENTER COMPONENT NAME = DFLT_COMP 

   $SITUATION NAME = STEP_1
       DFLT_COMP  SYSTEM = S_STEP_1  CONSTRAINTS = C_STEP_1  LOADING = L_STEP_1
   $END SITUATION

   $STRUCTURE

      $NSET NAME = GROUND
          100

      $NSET NAME = FREE
          101

      $NODE NSET = ALL_NODES
        100  0.0  0.0  0.0
        101  1.0  0.0  0.0

      $ELEMENT TYPE = MASS3 ESET = M
          1  101

      $ELEMENT TYPE = DAMP1 ESET = C
          2  100  101

      $ELEMENT TYPE = SPRING1 ESET = K
          3  100  101

      $ELEMENT TYPE = NLSTIFF ESET = NL_K
          4  100  101
 
   $END STRUCTURE

   $SYSTEM NAME = S_STEP_1

      $GEODAT MASS CONT = MASS 
         GD_M  M(1)

      $GEODAT DAMPER CONT = DAMP
         GD_C  C(1)

      $GEODAT SPRING CONT = STIFF
         GD_K  K(1)

      $GEODAT SPRING CONT = FUNCTION
         GD_NL_K  DUFFING

      $ELPROP
          M     GEODAT = GD_M
          C     GEODAT = GD_C
          K     GEODAT = GD_K
          NL_K  GEODAT = GD_NL_K
   
   $END SYSTEM

   $CONSTRAINTS NAME = C_STEP_1

      $SUPPRESS DOFS = 2,3
          ALL_NODES

      $SUPPRESS DOFS = 1
          GROUND
 
   $END CONSTRAINTS

   $LOADING NAME = L_STEP_1

      $INIVAL DISP 
          FREE 1: 0.0
      $INIVAL VELO 
          FREE 1: 0.0
  
      $CONLOAD LPAT = 1
          FREE  1: 1.0

      $TRANSLOAD
          LPAT = 1 FUNCTION = BIPERIODIC 

   $END LOADING

$EXIT COMPONENT
$ENTER FUNCTION 

    $FUNCTION FORMULA LABEL = DUFFING
       F(X) = GAMMA(1)*X^3

    $FUNCTION FORMULA LABEL = BIPERIODIC
       F(T) = F(1)*SIN(SQRT(2)*2*PI*FREQ(1)*T) + F(2)*SIN(2*PI*FREQ(1)*T)

$EXIT FUNCTION
$FIN