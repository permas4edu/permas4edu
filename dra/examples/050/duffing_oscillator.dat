$DEFVAR M TYPE = REAL LIST = 1.0
$DEFVAR ALPHA TYPE = REAL LIST = 1.0
$DEFVAR BETA TYPE = REAL LIST = -1.0
$DEFVAR A TYPE = REAL LIST = 0.9486832980505138 1.0 2.0

$ENTER COMPONENT NAME = DFLT_COMP 

   $SITUATION NAME = STEP_1
       DFLT_COMP  SYSTEM = S_STEP_1  CONSTRAINTS = C_STEP_1  LOADING = L_STEP_1
   $END SITUATION

   $STRUCTURE

      $NSET NAME = GROUND
          100

      $NSET NAME = FREE
          101

      $NODE NSET = ALL_NODES
        100  0.0  0.0  0.0
        101  1.0  0.0  0.0

      $ELEMENT TYPE = MASS3 ESET = M
          1  101

      $ELEMENT TYPE = SPRING1 ESET = ALPHA
          2  100  101

      $ELEMENT TYPE = NLSTIFF ESET = NL_K
          3  100  101
 
   $END STRUCTURE

   $SYSTEM NAME = S_STEP_1

      $GEODAT MASS CONT = MASS 
         GD_M  M(1)

      $GEODAT SPRING CONT = STIFF
         GD_ALPHA  ALPHA(1)

      $GEODAT SPRING CONT = FUNCTION
         GD_NL_K  DUFFING

      $ELPROP
          M     GEODAT = GD_M
          ALPHA GEODAT = GD_ALPHA
          NL_K  GEODAT = GD_NL_K
   
   $END SYSTEM

   $CONSTRAINTS NAME = C_STEP_1

      $SUPPRESS DOFS = 2,3
          ALL_NODES

      $SUPPRESS DOFS = 1
          GROUND
 
   $END CONSTRAINTS

   $LOADING NAME = L_STEP_1

      $INIVAL DISP 
          FREE 1: A(1)  ! oscillation amplitude
      $INIVAL VELO 
          FREE 1: 0.0
  
      $CONLOAD LPAT = 1
          FREE  1: 1.0

      $TRANSLOAD
          LPAT = 1 FUNCTION = ZERO

   $END LOADING

$EXIT COMPONENT
$ENTER FUNCTION 

    $FUNCTION FORMULA LABEL = DUFFING
       F(X) = BETA(1)*X^3

    $FUNCTION FORMULA LABEL = ZERO
       F(T) = 0.0

$EXIT FUNCTION
$FIN