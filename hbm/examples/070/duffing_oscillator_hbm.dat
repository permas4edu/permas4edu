$DEFVAR M TYPE = REAL LIST = 1.0
! stiffness
$DEFVAR ALPHA TYPE = REAL LIST = 5.0 0.5
$DEFVAR BETA TYPE = REAL LIST = 0.1 3.0
! damping
$DEFVAR DELTA TYPE = REAL LIST = 0.02 0.05
! Excitation
$DEFVAR F TYPE = REAL LIST = 0.1 0.1
$DEFVAR OMEGA TYPE = REAL LIST = 5.0 0.3

$ENTER COMPONENT NAME = DFLT_COMP 

   $SITUATION NAME = STEP_1
       DFLT_COMP  SYSTEM = S_STEP_1  CONSTRAINTS = C_STEP_1  LOADING = L_STEP_1  RESULTS = R_STEP_1
   $END SITUATION

   $SITUATION NAME = STEP_2
       DFLT_COMP  SYSTEM = S_STEP_2  CONSTRAINTS = C_STEP_1  LOADING = L_STEP_2  RESULTS = R_STEP_2
   $END SITUATION

   $SITUATION NAME = STEP_3
       DFLT_COMP  SYSTEM = S_STEP_1  CONSTRAINTS = C_STEP_1  LOADING = L_STEP_1
   $END SITUATION

   $SITUATION NAME = STEP_4
       DFLT_COMP  SYSTEM = S_STEP_2  CONSTRAINTS = C_STEP_1  LOADING = L_STEP_2
   $END SITUATION
   $STRUCTURE

      $NSET NAME = GROUND
          100

      $NSET NAME = FREE
          101

      $NODE NSET = ALL_NODES
        100  0.0  0.0  0.0
        101  1.0  0.0  0.0

      $ELEMENT TYPE = MASS3 ESET = M
          1  101

      $ELEMENT TYPE = SPRING1 ESET = ALPHA
          2  100  101

      $ELEMENT TYPE = NLSTIFF ESET = NL_K
          3  100  101

      $ELEMENT TYPE = DAMP1 ESET = DELTA
          4  100  101
  
   $END STRUCTURE

   $SYSTEM NAME = S_STEP_1

      $GEODAT MASS CONT = MASS 
         GD_M  M(1)

      $GEODAT SPRING CONT = STIFF
         GD_ALPHA  ALPHA(1)

      $GEODAT DAMPER CONT = DAMP
         GD_DELTA DELTA(1)

      $GEODAT SPRING CONT = FUNCTION
         GD_NL_K  1

      $ELPROP
          M     GEODAT = GD_M
          ALPHA GEODAT = GD_ALPHA
          NL_K  GEODAT = GD_NL_K
          DELTA GEODAT = GD_DELTA
   
   $END SYSTEM

   $SYSTEM NAME = S_STEP_2

      $GEODAT MASS CONT = MASS 
         GD_M  M(1)

      $GEODAT SPRING CONT = STIFF
         GD_ALPHA  ALPHA(2)

      $GEODAT DAMPER CONT = DAMP
         GD_DELTA DELTA(2)

      $GEODAT SPRING CONT = FUNCTION
         GD_NL_K  2

      $ELPROP
          M     GEODAT = GD_M
          ALPHA GEODAT = GD_ALPHA
          NL_K  GEODAT = GD_NL_K
          DELTA GEODAT = GD_DELTA

   $END SYSTEM

   $CONSTRAINTS NAME = C_STEP_1

      $SUPPRESS DOFS = 2,3
          ALL_NODES

      $SUPPRESS DOFS = 1
          GROUND
 
   $END CONSTRAINTS

   $LOADING NAME = L_STEP_1

      $CONLOAD LPAT = 1
          FREE  1: F(1)

       $FREQLOAD 
           LPAT = 1 TYPE = COSINE

   $END LOADING

   $LOADING NAME = L_STEP_2

      $CONLOAD LPAT = 1
          FREE  1: F(2)

       $FREQLOAD 
           LPAT = 1 TYPE = COSINE


   $END LOADING

   $LOADING NAME = L_STEP_3
      $CONLOAD LPAT = 1
          FREE  1: F(1)
   $END LOADING

   $LOADING NAME = L_STEP_4
      $CONLOAD LPAT = 1
          FREE  1: F(2)
   $END LOADING

   $RESULTS NAME = R_STEP_1

      $FREQUENCY PRIMARY = EQUI XTYPE = OMEGA
         0.0 5.0 0.1

   $END RESULTS

   $RESULTS NAME = R_STEP_2

      $FREQUENCY PRIMARY = EQUI XTYPE = OMEGA
         0.0 0.3 0.1

   $END RESULTS

$EXIT COMPONENT
$ENTER FUNCTION 

    $FUNCTION FORMULA LABEL = 1
       F(X) = BETA(1)*X^3

    $FUNCTION FORMULA LABEL = 2
       F(X) = BETA(2)*X^3

$EXIT FUNCTION
$FIN
