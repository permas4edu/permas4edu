NEW

INPUT
    READ PERMAS FILE = zhouzhou.dat
    READ PERMAS FILE = zhouzhou_sampling.dat
RETURN

TASK LOOPS = 125
EXEC
    ACT SIT = STEP_1
    VIBRATION ANALYSIS MODES = 3
    ACT SIT = SAMPLING
    SAMPLING
TASK END
EXPORT
    ITEM CLEAR
    ITEM XYDATA TYPE = DHIS
    ITEM XYDATA TYPE = SRHIS
    GO PERMAS BINARY FILE = sampling
    GO SPREADSHEET FILE = sampling
STOP
